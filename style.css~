/* Основные настройки */
html, body {
    margin: 0;
    padding: 0;
    font-family: "Inter", Arial, sans-serif;
    background: #f5f7fb;
    color: #1e1e1e;
}

/* Контейнер */
.container {
    max-width: 900px;
    margin: 0 auto;
    padding: 20px;
}

/* Шапка */
header {
    text-align: center;
    padding: 40px 0 20px 0;
}

header img.logo {
    width: 90px;
    height: 90px;
    margin-bottom: 15px;
}

/* Навигация */
nav {
    text-align: center;
    padding: 15px 0;
    margin-bottom: 25px;
}

nav a {
    margin: 0 12px;
    font-size: 18px;
    color: #4b4bff;
    text-decoration: none;
    font-weight: 600;
}

nav a:hover {
    text-decoration: underline;
}

nav a.active {
    font-weight: 600;
    border-bottom: 2px solid #2c7be5;
    padding-bottom: 2px;
}

/* Блок контента */
.content {
    background: #ffffff;
    padding: 30px;
    border-radius: 12px;
    box-shadow: 0 0 12px rgba(0,0,0,0.07);
    margin-bottom: 40px;
}

/* Заголовки */
h1 {
    font-size: 38px;
    margin-bottom: 10px;
}

h2 {
    margin-top: 0;
    color: #333;
}


footer {
    margin-top: 60px;
    padding-top: 20px;
    border-top: 1px solid #e0e0e0;
    font-size: 0.9em;
    color: #666;
    text-align: center;
}


/* Стили package-info */
.package-info {
    background: #eef3ff;
    border: 1px solid #d8e1ff;
    border-radius: 6px;
    padding: 15px 20px;
    margin-top: 10px;
    margin-bottom: 30px;
}

/* Стилизация списка внутри выделенного блока */
.package-info ul {
    /* Удаляем верхний отступ списка, чтобы он был ближе к вводному тексту */
    margin-top: 5px;
}

.link-block {
    margin-top: 12px;
    line-height: 1.6;
}

.link-block div {
    margin-bottom: 4px;
}

.link-label {
    font-weight: 600;
    color: #333;
    margin-right: 6px;
}

.link-block a {
    color: #4b4bff;
    text-decoration: none;
    font-weight: 500;
}

.link-block a:hover {
    text-decoration: underline;
}

.placeholder-box {
    position: relative;
    padding-left: 55px; /* место под номер */
}

.placeholder-box.future {
    background: #fff8c6; /* мягкий жёлтый */
    border-color: #e6d878;
}

/* Для адаптивного дизайна */
/* Базовая адаптивность */
*,
*::before,
*::after {
    box-sizing: border-box;
}

html {
    -webkit-text-size-adjust: 100%;
}

body {
    line-height: 1.65;
}

/* Картинки */
img {
    max-width: 100%;
    height: auto;
}

/* Читаемость текста */
p,
li {
    line-height: 1.7;
}

.content p,
.content li,
.lang-section p,
.lang-section li {
    max-width: 72ch;
}

/* Более мягкая адаптация контейнера */
.container {
    width: min(100% - 24px, 900px);
    padding: 20px 0;
}

/* Плавный responsive text */
h1 {
    font-size: clamp(2rem, 5vw, 38px);
    line-height: 1.15;
}

h2 {
    font-size: clamp(1.35rem, 3vw, 1.9rem);
    line-height: 1.25;
}

/* Немного адаптируем навигацию */
nav {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 10px 18px;
}

nav a {
    margin: 0;
    font-size: clamp(16px, 2vw, 18px);
}

/* package-info на маленьких экранах смотрится лучше */
.package-info {
    padding: 15px 18px;
}

/* Планшеты */
@media (max-width: 768px) {
    header {
        padding: 30px 0 16px 0;
    }

    header img.logo {
        width: 78px;
        height: 78px;
        margin-bottom: 12px;
    }

    .content {
        padding: 24px;
        border-radius: 10px;
    }

    nav {
        margin-bottom: 20px;
    }
}

/* Телефоны */
@media (max-width: 480px) {
    .container {
        width: min(100% - 18px, 900px);
    }

    header {
        padding: 24px 0 14px 0;
    }

    header img.logo {
        width: 70px;
        height: 70px;
    }

    h1 {
        margin-bottom: 8px;
    }

    nav {
        flex-direction: column;
        align-items: center;
        gap: 10px;
        padding: 12px 0;
    }

    nav a {
        display: inline-block;
        padding: 4px 0;
    }

    .content {
        padding: 18px;
        border-radius: 10px;
        box-shadow: 0 0 10px rgba(0,0,0,0.06);
    }

    .package-info {
        padding: 14px 14px;
        margin-bottom: 22px;
    }

    footer {
        margin-top: 40px;
        padding-top: 16px;
        font-size: 0.86em;
    }
}

